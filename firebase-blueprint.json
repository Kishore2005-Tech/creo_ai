{
  "entities": {
    "content_history": {
      "title": "Content History",
      "description": "Historical generated content scoped to user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "contentType": { "type": "string" },
        "topic": { "type": "string" },
        "outputText": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["userId", "contentType", "topic", "outputText", "createdAt"]
    }
  },
  "firestore": {
    "/content_history/{docId}": {
      "schema": "content_history",
      "description": "Historical content logs"
    }
  }
}
